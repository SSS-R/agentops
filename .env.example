# AgentOps Relay Server Environment Variables

# Server Configuration
PORT=3000

# Database
DATABASE_PATH=./relay.db

# Temporal.io Configuration
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=agentops-queue

# Web Push Configuration (VAPID Keys)
# Generate new keys by running: cd packages/relay && npx ts-node src/utils/vapidKeys.ts
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Development
NODE_ENV=development
