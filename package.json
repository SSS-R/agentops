{
  "name": "agentops-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "The control plane for AI coding agents",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspace=@agentops/shared && npm run build --workspace=@agentops/relay && npm run build --workspace=@agentops/sdk && npm run build --workspace=@agentops/ui",
    "build:relay": "npm run build --workspace=@agentops/relay",
    "build:ui": "npm run build --workspace=@agentops/ui",
    "dev": "npm run dev --workspaces --if-present",
    "dev:relay": "npm run dev --workspace=@agentops/relay",
    "dev:ui": "npm run dev --workspace=@agentops/ui",
    "test": "npm run test --workspaces --if-present",
    "test:relay": "npm run test --workspace=@agentops/relay",
    "test:ui": "npm run test --workspace=@agentops/ui",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "node -e \"const fs=require('fs');['packages/relay/dist','packages/ui/dist','packages/sdk/dist','packages/shared/dist','node_modules'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\""
  },
  "keywords": [
    "ai-agents",
    "agent-orchestration",
    "temporal",
    "mcp",
    "developer-tools"
  ],
  "author": "AgentOps Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SSS-R/agentops.git"
  },
  "bugs": {
    "url": "https://github.com/SSS-R/agentops/issues"
  },
  "homepage": "https://github.com/SSS-R/agentops#readme",
  "dependencies": {
    "lucide-react": "^0.577.0"
  }
}
